# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.rs text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf

# Binary files (não fazer normalize)
*.png binary
*.jpg binary
*.ico binary
*.exe binary
*.msi binary
*.deb binary
*.AppImage binary